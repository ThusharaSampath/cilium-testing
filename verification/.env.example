# Choreo Console
CHOREO_CONSOLE_URL=https://consolev2.preview-dv.choreo.dev
CHOREO_ORG_HANDLE=thusharadev
CHOREO_ORG_ID=<your-org-id>
CHOREO_PROJECT_ID=<your-project-id>
CHOREO_PROJECT_HANDLER=cilium-verification

# GitHub repo connected to Choreo
GITHUB_REPO_NAME=ThusharaSampath/cilium-testing
GITHUB_BRANCH=main

# Google account name shown on the account chooser (for automatic re-login)
GOOGLE_ACCOUNT_NAME=Thushara Sampath

# Max minutes to poll for component builds/deploys before timing out (default: 20)
BUILD_WAIT_MINUTES=20

# AWS ECR (only required if your PDP pulls images from ECR — e.g. OpenShift on AWS)
AWS_REGISTRY=<your-ecr-registry>
AWS_REGISTRY_USER=<iam-access-key-id>
AWS_REGISTRY_PASSWORD=<iam-secret-access-key>

# --- Cluster overrides (auto-loaded by verification/scripts/cluster/common.sh) ---
# Defaults assume vanilla Kubernetes. Uncomment and adjust for your PDP.
#
# OpenShift example:
# CILIUM_NS=cilium
# DNS_NAMESPACE=openshift-dns
# DNS_LABEL=dns.operator.openshift.io/daemonset-dns=default
# DNS_SERVICE_DOMAIN=dns-default.openshift-dns.svc.cluster.local
# DNS_LABEL_NAME=OpenShift DNS
# APIM_NS=choreo-apim
