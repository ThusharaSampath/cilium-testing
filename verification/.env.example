# Choreo Console
CHOREO_CONSOLE_URL=https://console.choreo.dev

CHOREO_ORG_HANDLE=<your-org-handle>
CHOREO_ORG_ID=<your-org-id>
CHOREI_ORG_UUID=<your-org-uuid>

CHOREO_PROJECT_ID=<your-project-id>
CHOREO_PROJECT_HANDLER=<your-project-handle>

# GitHub repo connected to Choreo (contains the test service source code)
GITHUB_REPO_NAME=<owner>/<repo>
GITHUB_BRANCH=main

# Google account name shown on the account chooser (for automatic re-login)
GOOGLE_ACCOUNT_NAME="<Your Name>"

# Max minutes to poll for component builds/deploys before timing out (default: 20)
BUILD_WAIT_MINUTES=20

# Cluster specific settings (consumed by verification/scripts/cluster/*.sh)
# For OpenShift,
CILIUM_NS=cilium
DNS_NAMESPACE=openshift-dns
DNS_LABEL=dns.operator.openshift.io/daemonset-dns=default
DNS_SERVICE_DOMAIN=dns-default.openshift-dns.svc.cluster.local
DNS_LABEL_NAME="OpenShift DNS"
